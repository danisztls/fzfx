#!/usr/bin/env bash
# fzf specialized functional fuzzy searches
# dependencies: fzf, ripgrep, fd, trash-cli 
# optionals: ripgrep-all, grc

# Strict mode: exit on error, treat unset variables as errors, fail pipelines on
# any failing stage. Config/env vars that may be unset are guarded with ${var:-}.
set -euo pipefail

# HELP
printHelp() {
    printf "fzfx — fzf-powered fuzzy finder for common file and process tasks

USAGE:
    fzfx [MODE] [PATH]

MODES:
    \e[1m(none)\e[0m  find files (the default);
    \e[1mhidden\e[0m  find files, including hidden (.git and .cache excluded);
    \e[1mmd\e[0m      find markdown files;
    \e[1mpdf\e[0m     find and preview pdf and postscript files;
    \e[1mav\e[0m      find and play audio and video files;
    \e[1mpic\e[0m     find and view pictures;
    \e[1mfull\e[0m    full-text search inside files;
    \e[1mcd\e[0m      list sub-directories and print the selected one;
    \e[1mcp\e[0m      copy a selected file to the current directory;
    \e[1mmv\e[0m      move a selected file to a selected directory;
    \e[1mps\e[0m      list and manage processes;
    \e[1mhelp\e[0m    show this help (also -h, --help).

PATH defaults to \$HOME. Override via searchPath/searchLocal in the config.\n"
}

# CONFIG FILE
# Load config file
configDir="${XDG_CONFIG_HOME:-"$HOME/.config"}/fzfx"
configFile="$configDir/config"
#shellcheck disable=SC1090
[ -f "$configFile" ] && source "$configFile"

# Load ignore file
ignoreFile="$configDir/ignore"
[ -f "$ignoreFile" ] || ignoreFile="/usr/share/fzfx/ignore"

# Base fd command shared by the file/dir search modes; modes append --type and globs.
# (hidden mode is intentionally excluded, it uses --no-ignore --hidden instead)
fdBase="fd --follow --ignore-case --no-ignore-vcs --ignore-file $ignoreFile"

# Set editor: use $editor from config, otherwise, use $EDITOR, if defined, or whatever is available.
if ! [ "${editor:-}" ]; then
    # fallback chain, easiest to use first (not a preference; only used when $EDITOR is unset)
    editors=(nano micro vim nvim vi)
    # shellcheck disable=SC2153
    if [ "${EDITOR:-}" ]; then
        editor="$EDITOR"
    else
        for prog in "${editors[@]}"; do
            if [ "$(command -v "$prog")" ]; then
                # remove alias and path prefix
                editor=$(command -v "$prog" | sed 's/alias .*=//;s#.*/##')
                break # first available wins, i.e. the friendliest editor
            fi
        done
    fi
fi

# Set clipboard: use $clipboard from config, otherwise detect by environment
# (wl-copy on Wayland, xclip on X11, pbcopy on macOS).
if ! [ "${clipboard:-}" ]; then
    if [ "$(command -v wl-copy)" ]; then
        clipboard=wl-copy
    elif [ "$(command -v xclip)" ]; then
        clipboard=xclip
    elif [ "$(command -v pbcopy)" ]; then
        clipboard=pbcopy
    else
        clipboard=xclip
    fi
fi

# DEPENDENCY PREFLIGHT
# Required tools. Optional ones (bat, rga, grc, tree, evince, mpv, feh...) degrade gracefully.
missing=()
for dep in fzf fd rg; do
    command -v "$dep" >/dev/null 2>&1 || missing+=("$dep")
done
if [ "${#missing[@]}" -gt 0 ]; then
    printf 'fzfx: missing required dependencies: %s\n' "${missing[*]}" >&2
    exit 1
fi

# SEARCH PATH
# Parse arguments
# TODO: Make it work with ~
# when only argument is inputted is it mode or searchPath?
if [ $# -eq 1 ] && [ -d "$1" ]; then
    searchPath="$1"
elif [ $# -eq 2 ]; then
    searchPath="$2"
elif [ $# -gt 2 ]; then
    echo "Error, exceding number of arguments!" && exit 1
fi

# Check if a valid path is inputted and otherwise set $HOME
if ! [ -d "${searchPath:-}" ]; then
    searchPath="$HOME"
fi

# DEFAULTS
# f1 opens with xdg-open, f2 opens with text editor, f3 copy path to console clipboard,
# f4 echoes path to stdout, alt+shift+d move file to trash.
defaultBind="\
enter:become(printf '%s\\n' '$searchPath'/{}),\
f1:become(xdg-open {} 2>/dev/null),\
f2:become(${editor:-} {}),\
f3:become($clipboard <<< {}),\
f4:become(printf '%s\\n' '$searchPath'/{})"
defaultHeader="enter → default, f1 → open, f2 → edit, f3 → clip, f4 → print, alt+shift+d → delete, esc → exit"

if [ "$(command -v bat)" ]; then
    defaultPreview="bat --style=numbers --color=always --line-range :500 {}"
else
    defaultPreview="cat {}"
fi

defaultOpts="--preview-window=right:50%:wrap"

# Export Defaults
export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-} --bind '$defaultBind' --header '$defaultHeader' --preview '$defaultPreview' $defaultOpts"

# LIB
_fzf() {
    export FZF_DEFAULT_COMMAND="$query"
    fzf ${bind:+--bind "$bind"} ${preview:+--preview "$preview"} ${header:+--header "$header"} ${opts[@]+"${opts[@]}"} \
    --bind "alt-D:reload(trash {} && $query)" # can't be on $defaultBind as $query need to be declared
}

fzfDefault() {
# DEFAULT: find almost anything
    local query="$fdBase --type file"
    _fzf
}

fzfHidden() {
# HIDDEN: find anything including hidden files
    local query="fd --type file --follow --ignore-case --no-ignore --hidden"
    _fzf
}

fzfMd() {
# MD: find markdown notes
    local query="$fdBase --type file --glob '*.md'"
    _fzf
}

fzfPdf() {
# PDF: find preview pdf and postscript files
    local query="$fdBase --type file '^.*\.(pdf|ps|eps)$'"
    local bind
    if [ -z "${pdfView:-}" ]; then
        if [ "$(command -v evince)" ]; then
            pdfView="evince --preview"
        else
            pdfView="xdg-open"
        fi
    fi
    local bind="enter:execute-silent($pdfView {} 2>/dev/null)"
    local opts=(--preview-window hidden)
    _fzf
}

fzfAv() {
# AV: find video and audio files
    local query="$fdBase --type file '^.*\.(mkv|mp4|mtk|webm|avi|mp3|ogg|wav|wma|aac)$'"
    local bind
    if [ -z "${avView:-}" ]; then
        if [ "$(command -v mpv)" ]; then
            avView="mpv --no-terminal --length=5" # autclose after 5s
        else
            avView="xdg-open"
        fi
    fi
    local bind="enter:execute-silent($avView {} 2>/dev/null)"
    local opts=(--preview-window hidden)
    _fzf
} 

fzfPic() {
# PIC: find pictures, video and audio files
    local query="$fdBase --type file '^.*\.(mkv|mp4|webm|avi|webp|jpg|jpeg|png|gif)$'"
    if [ -z "${picView:-}" ]; then
        if [ "$(command -v feh)"  ]; then
            picView="feh --scale-down --auto-zoom"
        else
            picView="xdg-open"
        fi
    fi
    local bind="enter:execute-silent($picView {} 2>/dev/null)"
    local opts=(--preview-window hidden)
    _fzf
} 

# shellcheck disable=SC2120
fzfFull() {
# FULL: search inside files
# $1 is returned by fzf
    local query="echo Type to search..."
    local preview
    if [[ $(command -v rga) ]] && ! [ "${FZFX_DISABLE_RGA:-}" = "True" ]; then
        # use ripgrep-all
        queryFull="rga --ignore-case --no-ignore-vcs --files-with-matches --rga-adapters='-decompress,tar,zip,ffmpeg,sqlite' --ignore-file $ignoreFile ${1:-}"
        preview="rga --ignore-case --no-ignore-vcs --pretty --context 10 {q} {}"
    else
        # use ripgrep
        queryFull="rg --ignore-case --no-ignore-vcs --files-with-matches --no-messages --ignore-file $ignoreFile ${1:-}"
        preview="rg --ignore-case --no-ignore-vcs --pretty --no-line-number --context 10 {q} {}"
    fi
    local bind="change:reload($queryFull {q} || true)+preview($preview)"
    local opts=(--sort --phony --preview-window hidden)
    _fzf
}

fzfCd() {
# FCD: search dirs and cd to them
    local query="$fdBase --type directory"
    local preview
    if [ "$(command -v tree)" ]; then
        preview="tree -C -c {} | head -200"
    else
        preview="ls --color=always {} | head -200"
    fi
    _fzf
}

fzfPs() {
# FPS: search processes and manage them
# f1 term, f2 kill, f3 sleep, f4 wake
    local query="ps -Ao pid,cmd,%mem,%cpu,tt,user,time,stat"
    # if grc is installed append it to command prefix
    [ "$(command -v grc)" ] && query="grc --colour=on $query"
    # shellcheck disable=SC2031
    local opts=(--ansi --header-lines=1 --reverse --cycle --preview-window hidden)
    local bind="\
start:unbind(enter)+unbind(alt-D),\
change:reload($query),\
f1:reload(kill -15 {1} && sleep 0.15 && $query),\
f2:reload(kill -9 {1} && sleep 0.15 && $query),\
f3:reload(kill -19 {1} && sleep 0.15 && $query),\
f4:reload(kill -18 {1} && sleep 0.15 && $query)"
    local header="f1 → SIGTERM, f2 → SIGKILL, f3 → SIGSTOP, f4 → SIGCONT"
    _fzf
}

# MAIN
# Store local path for later use
pwd="$PWD" 

# Change directory to searchPath
# if searchLocal is on it will not cd
# shellcheck disable=SC2154 # it's external
if ! [ "${searchLocal:-}" ]; then
    # shellcheck disable=SC2164 # unneeded
    cd "$searchPath"
fi

case "${1:-}" in
    help|-h|--help) printHelp;;
    hidden) fzfHidden;;
    md) fzfMd;;
    pdf) fzfPdf;;
    av) fzfAv;;
    pic) fzfPic;;
    full) fzfFull;;
    cd) fzfCd;;
    cp)
        sel="$(fzfDefault)"
        [ -n "$sel" ] && cp -n "$sel" "$pwd/"
        ;;
    mv)
        sel="$(fzfDefault)"
        if [ -n "$sel" ]; then
            dst="$(fzfCd)"
            [ -n "$dst" ] && mv -n "$sel" "$dst"
        fi
        ;;
    ps) fzfPs;;
    *) fzfDefault;;
esac
